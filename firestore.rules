rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Every document lives under a single teacher's tree keyed by their uid.
    // Only that signed-in owner may read or write anything beneath it. This is
    // the REAL cross-tenant guarantee: a collectionGroup query over
    // feedbackHistory only ever returns docs whose path is under the caller's
    // own uid, so no teacher can read another teacher's students.
    match /teachers/{ownerUid}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == ownerUid;

      // ── HARDENING (recommended before storing real student PII) ────────────
      // The email allowlist is currently enforced only in the browser
      // (src/auth/useAuth.tsx). That stops a stranger from USING the app, but
      // any authenticated Google account can still create its OWN empty tree by
      // talking to Firestore directly. To enforce the allowlist server-side,
      // add your teacher account email(s) to the condition above and redeploy:
      //
      //   && request.auth.token.email in ['mr.b@yourdistrict.org']
      //   && request.auth.token.email_verified == true
      //
      // (Use the EXACT email of the Google account you sign in with, or you'll
      // lock yourself out. If you add email_verified, also pass
      // { email_verified: true } in the rules-unit-test auth contexts.)
      // Deploy with:  firebase deploy --only firestore:rules
    }

    // Anything outside a teacher tree is denied by default (no catch-all rule).
  }
}
