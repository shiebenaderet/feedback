{
  "indexes": [
    {
      "comment": "HomePage per-period progress: listFeedbackHistory filters ownerUid + yearId + courseId + periodId on the feedbackHistory collection group.",
      "collectionGroup": "feedbackHistory",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "ownerUid", "order": "ASCENDING" },
        { "fieldPath": "yearId", "order": "ASCENDING" },
        { "fieldPath": "courseId", "order": "ASCENDING" },
        { "fieldPath": "periodId", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "Year/course-scoped history: ownerUid + yearId + courseId.",
      "collectionGroup": "feedbackHistory",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "ownerUid", "order": "ASCENDING" },
        { "fieldPath": "yearId", "order": "ASCENDING" },
        { "fieldPath": "courseId", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "Whole-year history: ownerUid + yearId.",
      "collectionGroup": "feedbackHistory",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "ownerUid", "order": "ASCENDING" },
        { "fieldPath": "yearId", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "Per-student history with chronological order: ownerUid + yearId + courseId + periodId + studentId.",
      "collectionGroup": "feedbackHistory",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "ownerUid", "order": "ASCENDING" },
        { "fieldPath": "yearId", "order": "ASCENDING" },
        { "fieldPath": "courseId", "order": "ASCENDING" },
        { "fieldPath": "periodId", "order": "ASCENDING" },
        { "fieldPath": "studentId", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": [
    {
      "comment": "Single-field collection-group queries: listPeriodHistory (periodId==) and listCourseHistory (courseId==) need their fields indexed at COLLECTION_GROUP scope.",
      "collectionGroup": "feedbackHistory",
      "fieldPath": "periodId",
      "indexes": [
        { "order": "ASCENDING", "queryScope": "COLLECTION" },
        { "order": "ASCENDING", "queryScope": "COLLECTION_GROUP" }
      ]
    },
    {
      "collectionGroup": "feedbackHistory",
      "fieldPath": "courseId",
      "indexes": [
        { "order": "ASCENDING", "queryScope": "COLLECTION" },
        { "order": "ASCENDING", "queryScope": "COLLECTION_GROUP" }
      ]
    }
  ]
}
